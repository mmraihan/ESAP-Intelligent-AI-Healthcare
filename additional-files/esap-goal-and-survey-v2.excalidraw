eft", "verticalAlign": "middle", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 36, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "Data Type", "lineHeight": 1.25, "autoResize": true}, {"id": "s1_col_h3", "type": "text", "x": 660, "y": 756, "width": 120, "height": 16, "angle": 0, "strokeColor": "#343a40", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "Required?", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "middle", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 37, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "Required?", "lineHeight": 1.25, "autoResize": true}, {"id": "s1_col_h4", "type": "text", "x": 790, "y": 756, "width": 390, "height": 16, "angle": 0, "strokeColor": "#343a40", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "AI Pipeline Purpose", "fontSize": 12, "fontFamily": 1, "textAlign": "left", "verticalAlign": "middle", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 38, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "AI Pipeline Purpose", "lineHeight": 1.25, "autoResize": true}, {"id": "s1_rows", "type": "text", "x": 118, "y": 785, "width": 1066, "height": 544, "angle": 0, "strokeColor": "#343a40", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "Full Legal Name                    text                    Required    Patient identity anchor across all records and AI queries\nPreferred Name / Nickname          text                    Optional    Personalisation in patient-facing app and doctor UI\nDate of Birth                      date                    Required    Age calculation; age-specific risk models and drug dosage\nAge                                number (auto)           Auto        Rapid filtering: paediatric / adult / geriatric rules\nBiological Sex                     dropdown                Required    Sex-specific disease risk, medication metabolism, lab ranges\nGender Identity                    dropdown + free text    Optional    Inclusive care; hormone-related history, mental health context\nNationality                        dropdown                Required    Population-level epidemiological risk baselines\nEthnicity / Race                   multi-select            Optional    Genetic disease predisposition (sickle cell, BRCA, etc.)\nBlood Group                        dropdown A/B/AB/O Вұ     Required    Emergency transfusion; surfaced immediately in critical alerts\nHeight (cm)                        number                  Required    BMI calculation; drug dosage weight-based rules\nWeight (kg)                        number                  Required    BMI calculation; obesity-related risk stratification\nBMI                                number (auto)           Auto        Metabolic syndrome screening, surgical risk scoring\nMarital Status                     dropdown                Optional    Psychosocial context for mental health, chronic disease\nNumber of Dependents               number                  Optional    Family stress load; postpartum risk screening\nHighest Education Level            dropdown                Optional    Health literacy estimation; simplifies AI explanations\nReligion                           text                    Optional    Dietary restrictions (halal, kosher); transfusion consent flags\nProfile Photo                      file-upload             Optional    Visual identity confirmation in the doctor UI", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 39, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "Full Legal Name                    text                    Required    Patient identity anchor across all records and AI queries\nPreferred Name / Nickname          text                    Optional    Personalisation in patient-facing app and doctor UI\nDate of Birth                      date                    Required    Age calculation; age-specific risk models and drug dosage\nAge                                number (auto)           Auto        Rapid filtering: paediatric / adult / geriatric rules\nBiological Sex                     dropdown                Required    Sex-specific disease risk, medication metabolism, lab ranges\nGender Identity                    dropdown + free text    Optional    Inclusive care; hormone-related history, mental health context\nNationality                        dropdown                Required    Population-level epidemiological risk baselines\nEthnicity / Race                   multi-select            Optional    Genetic disease predisposition (sickle cell, BRCA, etc.)\nBlood Group                        dropdown A/B/AB/O Вұ     Required    Emergency transfusion; surfaced immediately in critical alerts\nHeight (cm)                        number                  Required    BMI calculation; drug dosage weight-based rules\nWeight (kg)                        number                  Required    BMI calculation; obesity-related risk stratification\nBMI                                number (auto)           Auto        Metabolic syndrome screening, surgical risk scoring\nMarital Status                     dropdown                Optional    Psychosocial context for mental health, chronic disease\nNumber of Dependents               number                  Optional    Family stress load; postpartum risk screening\nHighest Education Level            dropdown                Optional    Health literacy estimation; simplifies AI explanations\nReligion                           text                    Optional    Dietary restrictions (halal, kosher); transfusion consent flags\nProfile Photo                      file-upload             Optional    Visual identity confirmation in the doctor UI", "lineHeight": 1.55, "autoResize": true}, {"id": "s2_frame", "type": "rectangle", "x": 100, "y": 1360, "width": 1100, "height": 370, "angle": 0, "strokeColor": "#e67700", "backgroundColor": "#f8f9fa", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "version": 1, "versionNonce": 40, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false}, {"id": "s2_title", "type": "rectangle", "x": 100, "y": 1360, "width": 1100, "height": 40, "angle": 0, "strokeColor": "#e67700", "backgroundColor": "#e67700", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "version": 1, "versionNonce": 41, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false}, {"id": "s2_title_text", "type": "text", "x": 120, "y": 1370, "width": 700, "height": 22, "angle": 0, "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "SECTION 2  вҖ”  Contact & Emergency Details  (10 fields)", "fontSize": 15, "fontFamily": 1, "textAlign": "left", "verticalAlign": "middle", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 42, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "SECTION 2  вҖ”  Contact & Emergency Details  (10 fields