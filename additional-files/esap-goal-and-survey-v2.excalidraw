ull, "roundness": null, "version": 1, "versionNonce": 18, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "CLOSED-LOOP FLOW", "lineHeight": 1.25, "autoResize": true}, {"id": "flow_text", "type": "text", "x": 120, "y": 452, "width": 1060, "height": 22, "angle": 0, "strokeColor": "#1864ab", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "Patient Registration  вҶ’  Global Data Center  вҶ’  LLM + RAG  вҶ’  AI Agents  вҶ’  Doctor's Tab  вҶ’  Doctor Feedback  вҶ’  Record Update  вҶ’  loops back", "fontSize": 13, "fontFamily": 1, "textAlign": "left", "verticalAlign": "middle", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 19, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "Patient Registration  вҶ’  Global Data Center  вҶ’  LLM + RAG  вҶ’  AI Agents  вҶ’  Doctor's Tab  вҶ’  Doctor Feedback  вҶ’  Record Update  вҶ’  loops back", "lineHeight": 1.25, "autoResize": true}, {"id": "kpi_label", "type": "text", "x": 120, "y": 484, "width": 300, "height": 22, "angle": 0, "strokeColor": "#495057", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "KEY FEATURES", "fontSize": 13, "fontFamily": 1, "textAlign": "left", "verticalAlign": "middle", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 20, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "KEY FEATURES", "lineHeight": 1.25, "autoResize": true}, {"id": "kpi_text", "type": "text", "x": 120, "y": 508, "width": 1060, "height": 68, "angle": 0, "strokeColor": "#343a40", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "вңҰ RAG over patient records   вңҰ Real-time speech-to-text + conversation analysis   вңҰ Drug interaction engine   вңҰ Symptom correlation agent\nвңҰ Automated history summarisation   вңҰ Doctor feedback вҶ’ RLHF fine-tuning   вңҰ EHR / HL7 FHIR integration\nвңҰ Two products: Hospital Clinical Support  +  Patient Personal App   вңҰ Two-sided network effect data moat", "fontSize": 13, "fontFamily": 1, "textAlign": "left", "verticalAlign": "top", "groupIds": [], "frameId": null, "roundness": null, "version": 1, "versionNonce": 21, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false, "containerId": null, "originalText": "вңҰ RAG over patient records   вңҰ Real-time speech-to-text + conversation analysis   вңҰ Drug interaction engine   вңҰ Symptom correlation agent\nвңҰ Automated history summarisation   вңҰ Doctor feedback вҶ’ RLHF fine-tuning   вңҰ EHR / HL7 FHIR integration\nвңҰ Two products: Hospital Clinical Support  +  Patient Personal App   вңҰ Two-sided network effect data moat", "lineHeight": 1.4, "autoResize": true}, {"id": "survey_header_frame", "type": "rectangle", "x": 100, "y": 620, "width": 1100, "height": 60, "angle": 0, "strokeColor": "#2b8a3e", "backgroundColor": "#2b8a3e", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "groupIds": [], "frameId": null, "roundness": {"type": 3}, "version": 1, "versionNonce": 22, "isDeleted": false, "boundElements": [], "updated": 1, "link": null, "locked": false}, {"id": "survey_header_text", "type": "text", "x": 200, "y": 636, "width": 900, "height": 28, "angle": 0, "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "text": "PATIENT REGISTRATION SURVEY  вҖ”  10 Sections В· ~120 Fields  (Primary Stage: Collect full health profile before first consultation)", "fontSize": 16, "fontFamily": 1, "textAlign