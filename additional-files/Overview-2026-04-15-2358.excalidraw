      "seed": 1005975221,
      "version": 368,
      "versionNonce": 2054605950,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "AXoENxfAiwtfnxuSDbZDO",
          "type": "arrow"
        }
      ],
      "updated": 1779181416665,
      "link": null,
      "locked": false,
      "text": "Data Preprocessing: The AI agent cleans\nand organizes the aggregated data.\n\nHistory Summarization: It extracts key\npoints and important historical events\n(diagnoses, treatments, allergies, etc.).\n\nSymptom Correlation: The agent analyzes\nnew symptoms against the patient’s\nhistorical data to flag potential issues or\npatterns.",
      "fontSize": 31.889977271860953,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Data Preprocessing: The AI agent cleans and organizes the aggregated data.\n\nHistory Summarization: It extracts key points and important historical events (diagnoses, treatments, allergies, etc.).\n\nSymptom Correlation: The agent analyzes new symptoms against the patient’s historical data to flag potential issues or patterns.",
      "autoResize": false,
      "lineHeight": 1.15
    },
