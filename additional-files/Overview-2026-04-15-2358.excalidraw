        }
      ],
      "updated": 1779024593379,
      "link": null,
      "locked": false,
      "text": "The summarized patient history and any\nrelevant alerts or correlations are\npresented to the doctor (or nurse) via a\nuser interface.\n\nThis information is displayed in a concise\nand digestible format, allowing the\nclinician to quickly grasp the patient’s\nbackground.",
      "fontSize": 31.889977271860953,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The summarized patient history and any relevant alerts or correlations are presented to the doctor (or nurse) via a user interface.\n\nThis information is displayed in a concise and digestible format, allowing the clinician to quickly grasp the patient’s background.",
      "autoResize": false,
      "lineHeight": 1.15
    },
