      "seed": 373735157,
      "version": 246,
      "versionNonce": 144960315,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "efRRopypx-Y-Kax4i3uzM",
          "type": "arrow"
        },
        {
          "id": "Fg1EwSaBQvCYsoQXcvQB8",
          "type": "arrow"
        }
      ],
      "updated": 1779024593379,
      "link": null,
      "locked": false,
      "text": "The system retrieves the patient’s existing\nrecords (medical history, past visits, etc.).\n\nThe system gathers data from various\nsources (EHRs, lab results, imaging, etc.)\nrelated to the patient.\n\nThis data is formatted and fed into the\ncentral repository for processing.\n",
      "fontSize": 31.889977271860953,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The system retrieves the patient’s existing records (medical history, past visits, etc.).\n\nThe system gathers data from various sources (EHRs, lab results, imaging, etc.) related to the patient.\n\nThis data is formatted and fed into the central repository for processing.\n",
      "autoResize": false,
      "lineHeight": 1.15
    },
