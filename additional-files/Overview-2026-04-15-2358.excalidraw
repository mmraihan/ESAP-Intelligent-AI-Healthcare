    {
      "id": "m50d582dzTfrFgjo8fcNa",
      "type": "text",
      "x": -1102.3537683072313,
      "y": -339.69206379528623,
      "width": 577.6863835529838,
      "height": 403.40821248904103,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b24",
      "roundness": null,
      "seed": 813180117,
      "version": 404,
      "versionNonce": 714651483,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779024593380,
      "link": null,
      "locked": false,
      "text": "The doctor reviews the AI-generated\nsummary along with current clinical\nobservations.\n\nBased on this information, the doctor\nmakes diagnostic or treatment decisions.\n\n\nAny adjustments or corrections made by\nthe clinician can be fed back into the\nsystem to refine future AI suggestions.",
      "fontSize": 31.889977271860953,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The doctor reviews the AI-generated summary along with current clinical observations.\n\nBased on this information, the doctor makes diagnostic or treatment decisions.\n\n\nAny adjustments or corrections made by the clinician can be fed back into the system to refine future AI suggestions.",
      "autoResize": false,
      "lineHeight": 1.15
    },
